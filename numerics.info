(%i3) /* Outer product with self gives rank-1 matrix */
      v : ndarray([1, 2], [2]);
(%o3)            ndarray([2], DOUBLE-FLOAT)
(%i4) np_det(np_outer(v, v));
(%o4)                          0.0

