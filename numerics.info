1.1.3 Creating arrays
---------------------

(%i1) np_zeros([3, 3]);
(%o1)            ndarray([3, 3], DOUBLE-FLOAT)
(%i2) np_ones([2, 4]);
(%o2)            ndarray([2, 4], DOUBLE-FLOAT)
(%i3) np_arange(5);
(%o3)            ndarray([5], DOUBLE-FLOAT)
(%i4) np_linspace(0, 1, 5);
(%o4)            ndarray([5], DOUBLE-FLOAT)


