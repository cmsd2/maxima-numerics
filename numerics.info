(%o1)            ndarray([3, 2], DOUBLE-FLOAT)
(%i2) b : ndarray(matrix([1], [2], [3]));
(%o2)            ndarray([3, 1], DOUBLE-FLOAT)
(%i3) [x, residuals, rank, S] : np_lstsq(A, b);
(%o3)        [ndarray, ndarray, 2, ndarray]
(%i4) np_to_list(x);
(%o4)                  [0.0, 1.0]
(%i5) rank;
