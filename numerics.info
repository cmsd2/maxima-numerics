(%i3) /* Anti-correlation gives -1 */
      B : ndarray(matrix([1, 10], [3, 6], [5, 2]));
(%o3)            ndarray([3, 2], DOUBLE-FLOAT)
(%i4) np_to_matrix(np_corrcoef(B));
