.................

(%i1) /* Unit spacing: integral of [1, 2, 3] = 0.5*(1+2) + 0.5*(2+3) = 4 */
      np_trapz(ndarray([1, 2, 3], [3]));
(%o1)                          4.0
(%i2) /* Variable spacing: y=x^2 on [0,1,2] */
      x : ndarray([0, 1, 2], [3]);
(%o2)            ndarray([3], DOUBLE-FLOAT)
(%i3) y : ndarray([0, 1, 4], [3]);
(%o3)            ndarray([3], DOUBLE-FLOAT)
(%i4) np_trapz(y, x);
(%o4)                          3.0

