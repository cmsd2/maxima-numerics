/* Tests for np_minimize (L-BFGS optimization) */


/* === 1. Simple quadratic: f(x) = x1^2 + x2^2, minimum at origin === */

(
  f(x) := np_sum(np_pow(x, 2)),
  grad(x) := np_scale(2.0, x),
  x0 : ndarray([3.0, 4.0]),
  result : np_minimize(f, grad, x0),
  x_opt : result[1],
  f_opt : result[2],
  conv  : result[3],
  true
);
true;

/* Converged */
is(conv = true);
true;

/* Minimum value near zero */
is(f_opt < 1e-10);
true;

/* Solution near origin */
is(abs(np_ref(x_opt, 0)) < 1e-4);
true;

is(abs(np_ref(x_opt, 1)) < 1e-4);
true;

/* Shape preserved */
np_shape(x_opt);
[2];

/* === 2. Shifted quadratic: f(x) = (x1-3)^2 + (x2-5)^2 === */

(
  f2(x) := block([d], d : np_sub(x, ndarray([3.0, 5.0])), np_sum(np_pow(d, 2))),
  g2(x) := np_scale(2.0, np_sub(x, ndarray([3.0, 5.0]))),
  result2 : np_minimize(f2, g2, ndarray([0.0, 0.0])),
  x2 : result2[1],
  closeto(np_ref(x2, 0), 3.0) and closeto(np_ref(x2, 1), 5.0)
);
true;

/* === 3. Rosenbrock function: f(x,y) = (1-x)^2 + 100*(y-x^2)^2 === */

(
  f_rosen(x) := block([x1, x2],
    x1 : np_ref(x, 0), x2 : np_ref(x, 1),
    (1 - x1)^2 + 100 * (x2 - x1^2)^2),
  g_rosen(x) := block([x1, x2],
    x1 : np_ref(x, 0), x2 : np_ref(x, 1),
    ndarray([-2*(1 - x1) - 400*x1*(x2 - x1^2),
             200*(x2 - x1^2)])),
  result3 : np_minimize(f_rosen, g_rosen, ndarray([-1.0, 1.0]), 1e-10, 500),
  x3 : result3[1],
  closeto(np_ref(x3, 0), 1.0) and closeto(np_ref(x3, 1), 1.0)
);
true;

/* === 4. Custom tolerance and max_iter === */

(
  result4 : np_minimize(f, grad, ndarray([10.0, 10.0]), 1e-4, 50),
  result4[3]
);
true;

/* === 5. Multi-dimensional shape preservation (2D input) === */

(
  f5(x) := np_sum(np_pow(x, 2)),
  g5(x) := np_scale(2.0, x),
  x0_2d : np_reshape(ndarray([2.0, 3.0, 4.0]), [3, 1]),
  result5 : np_minimize(f5, g5, x0_2d),
  np_shape(result5[1])
);
[3, 1];

/* === 6. Lambda functions work === */

(
  result6 : np_minimize(
    lambda([x], np_sum(np_pow(x, 2))),
    lambda([x], np_scale(2.0, x)),
    ndarray([5.0, 5.0])),
  result6[3]
);
true;

/* === np_compile_gradient tests === */

/* === 7. Gradient bridge: simple quadratic w1^2 + w2^2 === */

(
  [f7, g7] : np_compile_gradient(w1^2 + w2^2, [w1, w2]),
  result7 : np_minimize(f7, g7, ndarray([3.0, 4.0])),
  xopt7 : result7[1],
  result7[3]
);
true;

/* Solution near origin */
is(abs(np_ref(xopt7, 0)) < 1e-4);
true;

is(abs(np_ref(xopt7, 1)) < 1e-4);
true;

/* === 8. Gradient bridge: Rosenbrock (1-x)^2 + 100*(y-x^2)^2 === */

(
  [f8, g8] : np_compile_gradient((1-x)^2 + 100*(y-x^2)^2, [x, y]),
  result8 : np_minimize(f8, g8, ndarray([-1.0, 1.0]), 1e-10, 500),
  x8 : result8[1],
  closeto(np_ref(x8, 0), 1.0) and closeto(np_ref(x8, 1), 1.0)
);
true;

/* === 9. Gradient bridge: call f_func and grad_func independently === */

(
  [f9, g9] : np_compile_gradient(3*a^2 + 2*b^2, [a, b]),
  pt : ndarray([1.0, 2.0]),
  /* f(1,2) = 3*1 + 2*4 = 11 */
  closeto(f9(pt), 11.0)
);
true;

/* grad(1,2) = [6*a, 4*b] = [6, 8] */
(
  gv : g9(pt),
  closeto(np_ref(gv, 0), 6.0) and closeto(np_ref(gv, 1), 8.0)
);
true;

/* === np_minimize expression mode tests === */

/* === 10. Expression mode: simple quadratic w1^2 + w2^2 === */

(
  res10 : np_minimize(w1^2 + w2^2, [w1, w2], ndarray([3.0, 4.0])),
  res10[3]
);
true;

is(res10[2] < 1e-10);
true;

/* === 11. Expression mode: Rosenbrock === */

(
  res11 : np_minimize((1-x)^2 + 100*(y-x^2)^2, [x, y],
                       ndarray([-1.0, 1.0]), 1e-10, 500),
  x11 : res11[1],
  closeto(np_ref(x11, 0), 1.0) and closeto(np_ref(x11, 1), 1.0)
);
true;

/* === 12. Expression mode: shifted quadratic 3*(a-2)^2 + (b-5)^2 === */

(
  res12 : np_minimize(3*(a-2)^2 + (b-5)^2, [a, b], ndarray([0.0, 0.0])),
  x12 : res12[1],
  closeto(np_ref(x12, 0), 2.0, 1e-6) and closeto(np_ref(x12, 1), 5.0, 1e-6)
);
true;
