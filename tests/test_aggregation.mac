/* Tests for aggregation functions */

(load("tests/test_helpers"), true);
true;

/* === Basic aggregation === */

/* sum */
(np_sum(ndarray(matrix([1,2],[3,4]))));
10.0;

/* mean */
(np_mean(ndarray(matrix([1,2],[3,4]))));
2.5;

/* min/max */
(A : ndarray(matrix([3,1],[4,2])),
 is(np_min(A) = 1.0 and np_max(A) = 4.0));
true;

/* dot product */
(a : np_arange(3),
 b : np_ones(3),
 closeto(np_dot(a, b), 3.0));
true;

/* === Aggregation with axis === */

/* np_min with axis */
(A : ndarray(matrix([3, 1], [4, 2])),
 is(np_to_list(np_min(A, 0)) = [3.0, 1.0]));
true;

(A : ndarray(matrix([3, 1], [4, 2])),
 is(np_to_list(np_min(A, 1)) = [1.0, 2.0]));
true;

/* np_max with axis */
(A : ndarray(matrix([3, 1], [4, 2])),
 is(np_to_list(np_max(A, 0)) = [4.0, 2.0]));
true;

(A : ndarray(matrix([3, 1], [4, 2])),
 is(np_to_list(np_max(A, 1)) = [3.0, 4.0]));
true;

/* np_argmin with axis */
(A : ndarray(matrix([3, 1], [4, 2])),
 is(np_to_list(np_argmin(A, 0)) = [0.0, 0.0]));
true;

(A : ndarray(matrix([3, 1], [4, 2])),
 is(np_to_list(np_argmin(A, 1)) = [1.0, 1.0]));
true;

/* np_argmax with axis */
(A : ndarray(matrix([3, 1], [4, 2])),
 is(np_to_list(np_argmax(A, 0)) = [1.0, 1.0]));
true;

(A : ndarray(matrix([3, 1], [4, 2])),
 is(np_to_list(np_argmax(A, 1)) = [0.0, 0.0]));
true;

/* np_var with axis */
(A : ndarray(matrix([1, 5], [3, 7])),
 v0 : np_to_list(np_var(A, 0)),
 /* col 0: mean=2, var=((1-2)^2+(3-2)^2)/2 = 1 */
 /* col 1: mean=6, var=((5-6)^2+(7-6)^2)/2 = 1 */
 list_closeto(v0, [1.0, 1.0]));
true;

(A : ndarray(matrix([1, 5], [3, 7])),
 v1 : np_to_list(np_var(A, 1)),
 /* row 0: mean=3, var=((1-3)^2+(5-3)^2)/2 = 4 */
 /* row 1: mean=5, var=((3-5)^2+(7-5)^2)/2 = 4 */
 list_closeto(v1, [4.0, 4.0]));
true;

/* np_std with axis */
(A : ndarray(matrix([1, 5], [3, 7])),
 s0 : np_to_list(np_std(A, 0)),
 list_closeto(s0, [1.0, 1.0]));
true;

(A : ndarray(matrix([1, 5], [3, 7])),
 s1 : np_to_list(np_std(A, 1)),
 list_closeto(s1, [2.0, 2.0]));
true;

/* === Sorting === */

/* np_sort 1D */
(is(np_to_list(np_sort(ndarray([3,1,4,1,5],[5]))) = [1.0, 1.0, 3.0, 4.0, 5.0]));
true;

/* np_sort 1D already sorted */
(is(np_to_list(np_sort(np_arange(5))) = [0.0, 1.0, 2.0, 3.0, 4.0]));
true;

/* np_sort 2D axis=0 — sort each column */
(A : ndarray(matrix([3, 1], [1, 4])),
 is(np_to_matrix(np_sort(A, 0)) = matrix([1.0, 1.0], [3.0, 4.0])));
true;

/* np_sort 2D axis=1 — sort each row */
(A : ndarray(matrix([3, 1], [1, 4])),
 is(np_to_matrix(np_sort(A, 1)) = matrix([1.0, 3.0], [1.0, 4.0])));
true;

/* np_sort does not mutate input */
(A : ndarray([3, 1, 2], [3]),
 B : np_sort(A),
 is(np_ref(A, 0) = 3.0 and np_ref(B, 0) = 1.0));
true;

/* np_argsort 1D */
(is(np_to_list(np_argsort(ndarray([3, 1, 2], [3]))) = [1.0, 2.0, 0.0]));
true;

/* np_argsort 2D axis=0 — row indices that sort each column */
(A : ndarray(matrix([3, 1], [1, 4])),
 is(np_to_matrix(np_argsort(A, 0)) = matrix([1.0, 0.0], [0.0, 1.0])));
true;

/* np_argsort 2D axis=1 — col indices that sort each row */
(A : ndarray(matrix([3, 1], [4, 2])),
 is(np_to_matrix(np_argsort(A, 1)) = matrix([1.0, 0.0], [1.0, 0.0])));
true;

/* np_sort 2D no axis — flatten and sort */
(A : ndarray(matrix([3, 1], [4, 2])),
 S : np_sort(A),
 is(length(np_shape(S)) = 1 and np_size(S) = 4));
true;

/* np_argsort round-trip: indexing by argsort gives sorted order */
(A : ndarray([5, 2, 8, 1], [4]),
 idx : np_argsort(A),
 /* idx should be [3, 1, 0, 2] => values at those positions: 1, 2, 5, 8 */
 is(np_to_list(idx) = [3.0, 1.0, 0.0, 2.0]));
true;

/* === Cumulative sum === */

/* np_cumsum: basic */
(A : ndarray([1, 2, 3, 4, 5], [5]),
 is(np_to_list(np_cumsum(A)) = [1.0, 3.0, 6.0, 10.0, 15.0]));
true;

/* np_cumsum: last element equals np_sum */
(A : ndarray([3, 1, 4, 1, 5], [5]),
 C : np_cumsum(A),
 closeto(np_ref(C, np_size(C) - 1), np_sum(A)));
true;
